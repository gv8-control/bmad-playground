{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": {
      "/tmp/**": "allow"
    }
  },
  "provider": {
    "neuralwatt": {
      "models": {
        "glm-5.2": {
          "limit": {
            "context": 1048560,
            "output": 1048560
          }
        }
      }
    }
  },
  "agent": {
    "planner": {
      "model": "neuralwatt/glm-5.2",
      "temperature": 0.6,
      "reasoningEffort": "max"
    },
    "coder": {
      "model": "neuralwatt/glm-5.2",
      "temperature": 0.25,
      "reasoningEffort": "max"
    }
  },
  "tools": {
    "skill": true
  }
}
