# apps/agent-be environment variables
#
# Copy to .env.local for local development. All variables listed here are
# validated at boot by Zod (src/config/env.validation.ts) — a missing or empty
# required variable fails loudly at startup, not silently after the sandbox
# is running (Story 6.1 AC-5).

# ─── Database ──────────────────────────────────────────────────────────────────
# Postgres connection string. Local dev: bmad_easy_test database.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bmad_easy_test

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Auth.js secret (shared with apps/web). Generate with: openssl rand -base64 32
# Also used as the boundary JWT signing key for apps/web → apps/agent-be.
AUTH_SECRET=

# ─── Anthropic API (Story 6.1) ────────────────────────────────────────────────
# Required. Injected into Daytona sandboxes as an env var so the Claude Code
# agent running inside the sandbox can authenticate with the Anthropic API.
# Fails loudly at startup (Zod env validation) if missing or empty.
ANTHROPIC_API_KEY=

# ─── Daytona Sandbox ──────────────────────────────────────────────────────────
# Leave blank in unit/integration tests — SandboxServiceFake is injected.
DAYTONA_API_URL=
DAYTONA_API_KEY=
