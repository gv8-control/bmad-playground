# Dependencies
node_modules/
# NOTE: .yarn/ MUST NOT be excluded — Yarn Berry uses it for patches/plugins/releases.
# The agent-be Dockerfile COPYs .yarn into the install stage; excluding it would
# silently produce an image without any patches.

# Git
.git/

# Build output
dist/
.next/
out/

# Nx cache
.nx/

# Environment files (secrets must never enter build context)
.env*
!.env.example

# Generated Prisma client (build artifact — Dockerfile runs prisma generate)
libs/database-schemas/src/generated/

# Test artifacts
playwright-report/
test-results/

# Deployment config
.railway/
.vercel/

# BMAD and docs
.claude/
_bmad-output/
docs/

# Markdown files
*.md
