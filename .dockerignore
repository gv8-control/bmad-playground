# Dependencies
node_modules/
# .yarn/patches, .yarn/plugins, .yarn/releases are tracked by git (see .gitignore)
# and will be included in the build context when they exist. .yarn/install-state.gz
# and other cache files are gitignored and excluded from the context.

# Git
.git/

# Build output
dist/
.next/
out/

# Nx cache
.nx/

# Environment files (secrets must never enter build context)
.env*
!.env.example

# Generated Prisma client (build artifact — Dockerfile runs prisma generate)
libs/database-schemas/src/generated/

# Test artifacts
playwright-report/
test-results/

# Deployment config
.railway/
.vercel/

# BMAD and docs
.claude/
_bmad-output/
docs/

# Markdown files
*.md
