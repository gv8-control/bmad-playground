# ─── Personal / Tooling Credentials ───────────────────────────────────────────
# These keys are NOT read by the application (apps/web, apps/agent-be) or by n8n.
# They are consumed by opencode, deployment CLIs, and external tools.
# Source this file before running those tools: set -a; source .env.local; set +a

# NeuralWatt API key — opencode provider for glm-5.2 (opencode.json)
NEURALWATT_API_KEY=

# n8n REST API key — for external scripts/tools calling the n8n REST API
N8N_API_KEY=

# Railway deployment token — railway CLI
RAILWAY_TOKEN=

# Vercel deployment token — vercel CLI
VERCEL_TOKEN=

UPTIMEROBOT_API_KEY=

# ─── Tailscale (Workstream G — external accessibility) ─────────────────────────
# Pre-generated auth key from https://login.tailscale.com/admin/settings/keys
# Allows non-interactive (re)authentication on Codespace start/rebuild.
# Without this, `tailscale up` prints a URL that must be opened manually.
TAILSCALE_AUTH_KEY=
