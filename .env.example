# ─── Auth.js (next-auth v5) ────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
# Also used as the boundary JWT signing key for apps/web → apps/agent-be
# communication (no separate JWT_SECRET env var needed).
AUTH_SECRET=

# GitHub OAuth App credentials (https://github.com/settings/developers)
# Callback URL: http://localhost:3000/api/auth/callback/github
# For the OAuth redirect/scope E2E test only, AUTH_GITHUB_ID can be any non-empty string
# (e.g. fake_client_id_for_e2e) — a real OAuth App registration is not required.
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Base URL of the web app (used by Auth.js for callback URL construction)
AUTH_URL=http://localhost:3000

# ─── Test Environment ──────────────────────────────────────────────────────────
TEST_ENV=local

# ─── App URLs ──────────────────────────────────────────────────────────────────
BASE_URL=http://localhost:3000
API_URL=http://localhost:3001

# ─── GitHub OAuth Test Account ─────────────────────────────────────────────────
# A dedicated GitHub test account (not a real user's account).
TEST_GITHUB_USERNAME=
TEST_GITHUB_PASSWORD=
TEST_GITHUB_OTP_SECRET=   # TOTP secret if 2FA is enabled on the test account

# ─── Test Repository ───────────────────────────────────────────────────────────
# A GitHub repository the test account has write access to.
TEST_GITHUB_REPO_URL=https://github.com/your-org/test-bmad-repo

# ─── Database ──────────────────────────────────────────────────────────────────
# Used by NestJS integration tests to connect to the test database.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bmad_easy_test

# ─── Daytona Sandbox ───────────────────────────────────────────────────────────
# Leave blank in unit/integration tests — SandboxServiceFake is injected instead.
DAYTONA_API_URL=
DAYTONA_API_KEY=

# ─── LLM Spend Monitoring (NFR-O1) ──────────────────────────────────────────
# Per-user monthly LLM spend alert threshold in USD.
# Architecture default: $20/user/month. Alert fires as a structured warn log
# when a user's calendar-month-to-date spend exceeds this value.
# PM may revise; this is env-configurable so no code change is needed.
LLM_SPEND_ALERT_THRESHOLD_USD=20

# ─── Mid-session Sandbox Idle Timeout (Story 3.9) ──────────────────────────────
# Mid-session sandbox idle timeout in milliseconds (default 900000 = 15 min)
# A sandbox is torn down after this period of no user message activity mid-conversation
MID_SESSION_IDLE_TIMEOUT_MS=900000

# ─── Encryption ────────────────────────────────────────────────────────────────
# AES-256-GCM key for OAuth token encryption. 32-byte hex string.
# Generate with: openssl rand -hex 32
# Rotation procedure: docs/runbooks/kek-rotation.md
CREDENTIAL_ENCRYPTION_KEK=REPLACE_WITH_OPENSSL_RAND_HEX_32

# ─── n8n ───────────────────────────────────────────────────────────────────────
EXECUTIONS_MODE=queue
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=http
GENERIC_TIMEZONE=UTC
N8N_INSTANCE_OWNER_MANAGED_BY_ENV=true
N8N_INSTANCE_OWNER_EMAIL=dev@dev.dev
# bcrypt hash of "dev"
N8N_INSTANCE_OWNER_PASSWORD_HASH="\$2a\$10\$FRAwNj1p7F5ijej60UHu9u1Fwa70I.zspRU944FOsdBK/lRFSsDii"
N8N_PERSONALIZATION_SURVEY_ENABLED=false
N8N_DIAGNOSTICS_ENABLED=false
N8N_MCP_MANAGED_BY_ENV=true
N8N_MCP_ACCESS_ENABLED=true
N8N_ENCRYPTION_KEY=IX+P/MD5U3AtTqlbfISuM8RjpFV5eoHW
EXTERNAL_HOOK_FILES=/workspaces/bmad-playground/n8n/hooks.js
N8N_RESTRICT_FILE_ACCESS_TO=""
NODES_EXCLUDE=[]
NODE_FUNCTION_ALLOW_EXTERNAL=uuid
QUEUE_BULL_REDIS_HOST=localhost
QUEUE_BULL_REDIS_PORT=6379
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=localhost
DB_POSTGRESDB_PORT=5433
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=postgres
DB_POSTGRESDB_PASSWORD=postgres

# MCP server auth token — set this to your actual token
N8N_MCP_TOKEN=

# ─── opencode (BMAD pipeline runner) ───────────────────────────────────────────
# opencode hardcodes max output tokens at 32,000 (OUTPUT_TOKEN_MAX in transform.ts).
# GLM-5.2 supports up to 128K output. Without this flag, reasoning-heavy steps
# (e.g. validate-story) exhaust the 32K budget on reasoning alone and exit with
# stop_reason "length" before producing a response.
OPENCODE_EXPERIMENTAL_OUTPUT_TOKEN_MAX=128000
