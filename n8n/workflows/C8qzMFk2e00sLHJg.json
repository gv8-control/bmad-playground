    {
      "parameters": {
        "command": "=set -a; . /workspaces/bmad-playground/.env.local 2>/dev/null; set +a\nerr=$(mktemp)\nout=$(timeout --kill-after=60 5400 opencode run \\\n  --dangerously-skip-permissions \\\n  --title \"{{ $json.conversationTitle }}\" \\\n  --format json \\\n  --agent \"{{ $json.opencodeAgent }}\" \\\n  \"skill {{ $('Start').item.json.Skill }}\n{{ $('Start').item.json['Initial prompt (without story ID)'] }}\n\n{{ $json.storySpecificPrompt }}\" < /dev/null 2>\"$err\")\nrc=$?\nsalvaged=\"$([ -n \"$out\" ] && echo yes || echo no)\"\nprintf '%s\\n' \"$out\" | tail -n 10\nprintf '{\"type\":\"runner_meta\",\"rc\":%d,\"salvaged\":\"%s\"}\\n' \"$rc\" \"$salvaged\"\nif [ $rc -ne 0 ] || printf '%s\\n' \"$out\" | grep -q '\"type\":\"error\"'; then\n  if [ -s \"$err\" ]; then\n    stderrTail=\"$(tail -c 600 \"$err\")\"\n  else\n    stderrTail=\"$(printf '%s\\n' \"$out\" | grep '\"type\":\"error\"' | tail -c 600)\"\n  fi\n  stderrTail=\"$(printf '%s' \"$stderrTail\" | sed -E 's/(Bearer [A-Za-z0-9._-]+)/Bearer [REDACTED]/g; s/(sk-[A-Za-z0-9._-]+)/sk-[REDACTED]/g')\"\n  category=\"unknown\"\n  if printf '%s' \"$stderrTail\" | grep -qi 'authorization\\|api.key\\|auth'; then category=\"auth\"; elif printf '%s' \"$stderrTail\" | grep -qi 'rate.limit\\|429\\|quota'; then category=\"rate-limit\"; elif printf '%s' \"$stderrTail\" | grep -qi 'context.length\\|token\\|too long'; then category=\"context-length\"; fi\n  jq -cn --arg ts \"$(date -u +%FT%TZ)\" --arg context \"{{ $json.conversationTitle }} / initial run\" --argjson rc $rc --arg salvaged \"$salvaged\" --arg stderrTail \"$stderrTail\" --arg category \"$category\" '{ts:$ts,source:\"opencode-runner\",context:$context,rc:$rc,salvagedOutput:$salvaged,stderrTail:$stderrTail,category:$category}' >> _bmad-output/pipeline/runner-errors.jsonl\n  [ -s \"$err\" ] && tail -c 600 \"$err\" >&2\nfi\nrm -f \"$err\"\nif [ $rc -ne 0 ] && [ -z \"$out\" ]; then exit $rc; fi\nexit 0"
      },
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        256,
        16
      ],
