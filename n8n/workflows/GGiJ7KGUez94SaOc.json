    {
      "parameters": {
        "jsCode": "const step = $input.first().json;\nconst startedAt = Date.now();\nconst payload = { type: 'step_start', story: step.story, runId: step.RunId, step: step.id, index: step.index, total: step.total };\nconst b64 = Buffer.from(JSON.stringify(payload)).toString('base64');\nreturn [{ json: { ...step, startedAt, journalCmd: `node scripts/pipeline/journal.mjs append --b64 ${b64}` } }];"
