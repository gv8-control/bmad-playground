        "jsCode": "const s = $input.first().json;\nconst payload = { type: 'story_start', story: s.Story, runId: s.RunId, attempt: Number(s.Attempt ?? 1) };\nconst b64 = Buffer.from(JSON.stringify(payload)).toString('base64');\nreturn [{ json: { Story: s.Story, RunId: s.RunId, journalCmd: `node scripts/pipeline/journal.mjs append --b64 ${b64}` } }];"
