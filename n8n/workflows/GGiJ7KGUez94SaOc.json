      "parameters": {
        "jsCode": "const a = $('Assess step result').first().json;\nconst failMessage = `Step ${a.stepId} (${a.stepLabel}) failed for story ${a.story}: ${a.error}`;\nconst payload = { type: 'story_end', story: a.story, runId: a.RunId, status: 'failed', failedStep: a.stepId, error: a.error };\nconst b64 = Buffer.from(JSON.stringify(payload)).toString('base64');\nreturn [{ json: { Story: a.story, RunId: a.RunId, status: 'failed', failedStep: a.stepId, failMessage, journalCmd: `node scripts/pipeline/journal.mjs append --b64 ${b64}` } }];"
