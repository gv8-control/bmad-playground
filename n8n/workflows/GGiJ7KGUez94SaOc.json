        "jsCode": "const run = $('Prep run').first().json;\nconst parsed = JSON.parse($input.first().json.stdout);\nconst steps = Array.isArray(parsed) ? parsed : parsed.steps;\nreturn steps.map(s => ({ json: { ...s, RunId: run.RunId } }));"
