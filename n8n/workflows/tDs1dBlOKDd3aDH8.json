      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const stdout = $input.first().json.stdout;\nconst rc = $input.first().json.rc;\nconst lines = stdout.split(\"\\n\").filter(l => l.trim()).map(l => JSON.parse(l));\nconst textItem = lines.filter(item => item.type === \"text\").pop();\nreturn [{ json: { response: textItem.part.text, rc } }];"
      }
    }
  ],
