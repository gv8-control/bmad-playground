{
  "name": "BMad Easy Dev",
  "image": "mcr.microsoft.com/devcontainers/universal:5",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers-extra/features/n8n:1": {}
  },
  "forwardPorts": [3000, 3001, 5432, 5678],
  "portsAttributes": {
    "3000": { "label": "Web App", "onAutoForward": "notify" },
    "3001": { "label": "API", "onAutoForward": "notify" },
    "5432": { "label": "PostgreSQL", "onAutoForward": "silent" },
    "5678": { "label": "n8n Workflows", "onAutoForward": "openBrowser" }
  },
  "remoteEnv": {
    "N8N_HOST": "0.0.0.0",
    "N8N_PORT": "5678",
    "N8N_PROTOCOL": "http",
    "GENERIC_TIMEZONE": "UTC",
    "N8N_INSTANCE_OWNER_MANAGED_BY_ENV": "true",
    "N8N_INSTANCE_OWNER_EMAIL": "dev@dev.dev",
    "N8N_INSTANCE_OWNER_PASSWORD_HASH": "$2a$10$FRAwNj1p7F5ijej60UHu9u1Fwa70I.zspRU944FOsdBK/lRFSsDii",
    "N8N_PERSONALIZATION_SURVEY_ENABLED": "false",
    "N8N_DIAGNOSTICS_ENABLED": "false",
    "NODES_EXCLUDE": "[]"
  },
  "postCreateCommand": "npm install -g pnpm@10 && pnpm install",
  "postStartCommand": "docker compose up -d",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "postman.postman-for-vscode",
        "cweijan.vscode-postgresql-client2",
        "anthropic.claude-code"
      ]
    }
  }
}
