generator client {
  provider   = "prisma-client-js"
  output     = "../generated/client"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String           @id @default(cuid())
  githubId        String           @unique @map("github_id")
  githubLogin     String           @map("github_login")
  name            String?
  email           String?          @unique
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  oauthCredential OAuthCredential?
  repoConnection  RepoConnection?

  @@map("users")
}

model OAuthCredential {
  id             String   @id @default(cuid())
  userId         String   @unique @map("user_id")
  encryptedDek   String   @map("encrypted_dek")
  dekNonce       String   @map("dek_nonce")
  encryptedToken String   @map("encrypted_token")
  tokenNonce     String   @map("token_nonce")
  kekId          String   @map("kek_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("oauth_credentials")
}

model RepoConnection {
  id               String   @id @default(cuid())
  userId           String   @unique @map("user_id")
  repoUrl          String   @map("repo_url")
  credentialHealth String   @default("healthy") @map("credential_health")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("repo_connections")
}
